# Required
OPENAI_API_KEY="your-api-key"

# Optional
OPENAI_BASE_URL="https://your-proxy-or-leave-empty" # Self-hosted or gateway base URL (omit for public api.openai.com)
OPENAI_DEFAULT_MODEL="gpt-5.4-mini-2026-03-17" # Override default model name (defaults to gpt-5.4-mini-2026-03-17 if unset)
OPENAI_CLUE_MODEL="" # Separate model just for clue generation if desired

BACKEND_URL=""  # Deployed backend base URL, e.g., https://your-railway-service.up.railway.app

# CORS Configuration (backend)
# Set ALLOW_ALL_CORS=true ONLY for quick local experiments.
# EXTRA_CORS_ORIGINS can be a comma-separated list of additional allowed origins.
ALLOW_ALL_CORS="false"
EXTRA_CORS_ORIGINS=""  # e.g. https://staging-gridgpt.vercel.app,https://other.example